# ── Bitbucket credentials ──────────────────────────────────────────────────
# Bitbucket Cloud does NOT accept a plain Jira/Atlassian API token. Use ONE of:
#
# OPTION A — Atlassian API token WITH SCOPES (recommended, non-deprecated):
#   1. https://id.atlassian.com/manage-profile/security/api-tokens
#   2. "Create API token with scopes" → App: Bitbucket → scope: read:repository:bitbucket
#   3. Set BITBUCKET_EMAIL to your Atlassian account email, paste the token below.
#
# OPTION B — Bitbucket App Password:
#   1. https://bitbucket.org/account/settings/app-passwords/  → Create  → Repositories: Read
#   2. Set BITBUCKET_USERNAME to your Bitbucket USERNAME (not email), paste the password below.
#
# Auth uses BITBUCKET_USERNAME if set, otherwise BITBUCKET_EMAIL.
# Leave BITBUCKET_API_TOKEN empty to skip Bitbucket entirely (GitHub still works).

BITBUCKET_EMAIL=you@example.com
# BITBUCKET_USERNAME=
BITBUCKET_API_TOKEN=

# GitHub uses the `gh` CLI (already authenticated). No token needed here.
